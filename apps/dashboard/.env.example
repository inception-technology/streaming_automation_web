# Variables d'env Next.js — en local, utiliser `doppler run -- pnpm dev`.
# Vercel : configurées via l'intégration Doppler ↔ Vercel.

# Clerk (publishable = NEXT_PUBLIC_, secret = backend only)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Observability
NEXT_PUBLIC_SENTRY_DSN=
