# Variables d'env Next.js — en local, utiliser `doppler run -- pnpm dev`.
# Vercel : configurées via l'intégration Doppler ↔ Vercel.

# Clerk (publishable = NEXT_PUBLIC_, secret = backend only)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk — paths / redirects (lus automatiquement par ClerkProvider)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Backend — URL HTTP(S) de l'API. L'URL WebSocket est dérivée automatiquement
# (http→ws, https→wss) par le hook useStreamEvents, pas besoin d'une var
# séparée. Configurer un hostname distinct pour le WS nécessiterait un patch
# côté code.
NEXT_PUBLIC_API_URL=http://localhost:8000

# MediaMTX (optionnel, démos) — si set, affiche un bouton "Préset MediaMTX (×3)"
# sur la page détail d'un stream qui crée 3 cibles RTMP custom en 1 clic vers
# cette URL (stream keys : demo-twitch, demo-youtube, demo-facebook_live).
# À set sur le déploiement Vercel staging ; laisser vide en prod (cohérent
# avec ALLOW_CUSTOM_RTMP_TARGETS=false côté API prod).
# Exemple staging : rtmp://daring-intuition.railway.internal:1935
NEXT_PUBLIC_MEDIAMTX_RTMP_URL=

# Observability — non branché côté web actuellement, réservé pour Phase 1+.
NEXT_PUBLIC_SENTRY_DSN=
